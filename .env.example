# Judge model credentials.
OPENAI_API_KEY=

# Default public runner model credentials.
# These power the `provider_stub_chat` model in configs/models.yaml.
EVAL_API_KEY=
EVAL_BASE_URL=https://api.openai.com/v1
EVAL_MODEL_NAME=gpt-4.1-mini

# Optional provider-specific keys if you switch configs/models.
AWS_REGION=us-east-2
AWS_PROFILE=
Deepseek=
Xiaomi=

# Optional transport tuning.
EVAL_HTTP_TIMEOUT=120
EVAL_BEDROCK_CONNECT_TIMEOUT=10
EVAL_BEDROCK_READ_TIMEOUT=90
EVAL_BEDROCK_MAX_ATTEMPTS=2
